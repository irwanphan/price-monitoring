# Application
APP_NAME="Adata Price Monitor"
APP_VERSION="0.1.0"

# Database (PostgreSQL)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/price_monitor

# Redis (for Celery)
REDIS_URL=redis://redis:6379/0

# Zyte API (optional - leave empty to use Playwright)
ZYTE_API_KEY=

# Scraper Settings
SCRAPE_TIMEOUT=30
MAX_RETRIES=3

# Price Validation
DEFAULT_PRICE_TOLERANCE=0.3
